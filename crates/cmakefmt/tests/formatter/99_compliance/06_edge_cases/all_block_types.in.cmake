IF(CONDITION)
  SET(A 1)
  IF(NESTED)
    MESSAGE(STATUS "nested if")
  ELSEIF(OTHER)
    MESSAGE(STATUS "elseif")
  ELSE()
    MESSAGE(STATUS "else")
  ENDIF()
ENDIF()

WHILE(RUNNING)
  MESSAGE(STATUS "looping")
ENDWHILE()

FOREACH(item a b c)
  MESSAGE(STATUS ${item})
ENDFOREACH()

FUNCTION(my_func ARG)
  MESSAGE(STATUS ${ARG})
ENDFUNCTION()

MACRO(my_macro ARG)
  MESSAGE(STATUS ${ARG})
ENDMACRO()

BLOCK()
  SET(X 1)
ENDBLOCK()
